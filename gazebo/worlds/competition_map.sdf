    <!-- 경로점 ArUco 마커 4개 (DICT_4X4_50, 0.5m x 0.5m), 경계에서 1셀 이상 안쪽 -->

    <!-- 경로점 id=1: (4.2857, 4.0) -->
    <include>
      <uri>model://aruco_marker_id1_at_x4_y4</uri>
      <name>aruco_marker_id1_at_x4_y4</name>
      <pose>4.2857 4.0 0.002 0 0 0</pose>
    </include>
    <!-- 경로점 id=2: (4.2857, 16.0) -->
    <include>
      <uri>model://aruco_marker_id2_at_x4_y16</uri>
      <name>aruco_marker_id2_at_x4_y16</name>
      <pose>4.2857 16.0 0.002 0 0 0</pose>
    </include>
    <!-- 경로점 id=3: (25.7143, 4.0) -->
    <include>
      <uri>model://aruco_marker_id3_at_x26_y4</uri>
      <name>aruco_marker_id3_at_x26_y4</name>
      <pose>25.7143 4.0 0.002 0 0 0</pose>
    </include>
    <!-- 경로점 id=4: (12.8571, 12.0) -->
