      <uri>model://aruco_marker_id4_at_x13_y12</uri>
      <name>aruco_marker_id4_at_x13_y12</name>
      <pose>12.8571 12.0 0.002 0 0 0</pose>
    </include>

    <!-- 지상 고정 LiDAR 2대 (측위용, 33x23 금지구역 밖, 동쪽+북쪽 직교 배치) -->

    <!-- 지상 고정 LiDAR: ground_lidar_1 @ world (-1.5, -1.5, 1.5), yaw=0.6094 rad, topic /ouster1/points -->
    <model name="ground_lidar_1">
      <static>true</static>
      <pose>-1.5 -1.5 1.5 0.0 0.0 0.6094</pose>
      <link name="base">
        <visual name="pole">
          <pose>0 0 -0.75 0 0 0</pose>
          <geometry>
            <cylinder><radius>0.04</radius><length>1.5</length></cylinder>
          </geometry>
          <material>
            <ambient>0.15 0.15 0.15 1</ambient>
            <diffuse>0.25 0.25 0.25 1</diffuse>
          </material>
        </visual>
        <visual name="housing">
          <geometry>
            <cylinder><radius>0.09</radius><length>0.16</length></cylinder>
          </geometry>
          <material>
            <ambient>0.9 0.45 0.05 1</ambient>
            <diffuse>1.0 0.5 0.05 1</diffuse>
            <specular>0.3 0.3 0.3 1</specular>
            <emissive>0.3 0.15 0.0 1</emissive>
          </material>
        </visual>
        <visual name="cap">
          <pose>0 0 0.09 0 0 0</pose>
          <geometry>
            <cylinder><radius>0.07</radius><length>0.02</length></cylinder>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.85 1</ambient>
            <diffuse>0.9 0.9 0.95 1</diffuse>
          </material>
        </visual>
        <sensor name="ground_lidar_1_lidar" type="gpu_lidar">
          <always_on>1</always_on>
          <update_rate>10</update_rate>
          <topic>/ouster1</topic>
          <gz_frame_id>ground_lidar_1_frame</gz_frame_id>
          <visualize>true</visualize>
          <lidar>
            <scan>
              <horizontal>
                <samples>1024</samples>
                <resolution>1</resolution>
                <min_angle>-3.14159265358979</min_angle>
                <max_angle>3.14159265358979</max_angle>
              </horizontal>
              <vertical>
                <samples>64</samples>
                <resolution>1</resolution>
                <min_angle>-0.79234</min_angle>
                <max_angle>0.79234</max_angle>
              </vertical>
            </scan>
            <range>
              <min>0.3</min>
              <max>35.0</max>
              <resolution>0.001</resolution>
            </range>
            <noise>
              <type>gaussian</type>
              <mean>0.0</mean>
              <stddev>0.008</stddev>
            </noise>
          </lidar>
        </sensor>
      </link>
    </model>
    <!-- 지상 고정 LiDAR: ground_lidar_2 @ world (31.5, 21.5, 1.5), yaw=-2.5322 rad, topic /ouster2/points -->
    <model name="ground_lidar_2">
      <static>true</static>
      <pose>31.5 21.5 1.5 0.0 0.0 -2.5322</pose>
      <link name="base">
